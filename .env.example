# Copy to .env on the VM (git-ignored, never committed) and fill in real
# values. Used by docker-compose.yml.

# Comma-separated list of origins allowed to call the server (CORS +
# Socket.IO). Use your Cloudflare Pages project's stable *.pages.dev domain,
# not a per-deploy hash subdomain -- that changes on every deploy.
CLIENT_ORIGINS=https://your-project.pages.dev

# The public hostname Caddy requests a Let's Encrypt cert for. With no
# domain of your own, use nip.io against the VM's public IP, e.g. an
# instance at 123.45.67.89 becomes:
SERVER_HOSTNAME=123-45-67-89.nip.io
