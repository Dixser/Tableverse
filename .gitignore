# Dependencies
node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo

# Vite
.vite/
packages/*/dist/

# Test coverage
coverage/

# Databases (SQLite match/room storage created by packages/server)
*.sqlite3
*.sqlite
*.db

# Environment variables -- ignore every real env file, whatever the
# environment name (.env, .env.production, .env.staging, ...), at any
# depth (e.g. packages/client/.env.production). Keep the checked-in
# .example templates: they hold placeholder values only, documenting
# which keys a real .env file needs (see .env.example's own header).
.env*
!.env.example
!.env.*.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/

# OS artifacts
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code local settings (personal, not shared) -- launch.json is kept,
# it's project-wide dev-server config other contributors need too.
.claude/settings.local.json

#ssh
*.ssh