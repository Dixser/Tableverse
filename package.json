{
  "name": "tableverse",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:unit": "npm run test:unit --workspace=packages/shared --workspace=packages/game-core --workspace=packages/client --if-present",
    "test:integration": "npm run test:integration --workspace=packages/server --if-present",
    "lint": "eslint .",
    "new-game": "node scripts/new-game.mjs",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:client": "npm run dev --workspace=packages/client",
    "start": "npm run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vitest": "^2.1.4"
  }
}
